<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceApp.Mobile.Views.AuthPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto" Padding="0, 40, 0, 0">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="24, 0, 24, 24" Spacing="0">

                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0, 0, 0, 24">
                    <Border StrokeThickness="0" BackgroundColor="#1A003366" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 12" HorizontalOptions="Start">
                        <Label Text="school" TextColor="{StaticResource Primary}" FontFamily="MaterialIcons" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Grid.Column="1" Text="EduTrack Pro" TextColor="{StaticResource Primary}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="-48,0,0,0" />
                </Grid>

                <Border HeightRequest="200" StrokeShape="RoundRectangle 16" Stroke="#1A003366" StrokeThickness="1" BackgroundColor="#0D003366" Margin="0, 0, 0, 32">
                    <Image Source="campus_placeholder.png" Aspect="AspectFill" Opacity="0.5" />
                </Border>

                <Label Text="Welcome Back" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" FontSize="30" FontAttributes="Bold" Margin="0,0,0,8" />
                <Label Text="Secure biometric attendance for students" TextColor="{AppThemeBinding Light={StaticResource Slate600}, Dark={StaticResource Slate400}}" FontSize="16" Margin="0,0,0,24" />

                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Student ID" TextColor="{AppThemeBinding Light={StaticResource Slate700}, Dark={StaticResource Slate300}}" FontSize="14" FontAttributes="Bold" Margin="4,0,0,0" />
                        <Border Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate700}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate800}}" StrokeShape="RoundRectangle 12" HeightRequest="56">
                            <Grid ColumnDefinitions="48, *">
                                <Label Text="badge" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Placeholder="Enter your university ID" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" PlaceholderColor="{StaticResource Slate400}" BackgroundColor="Transparent" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Password" TextColor="{AppThemeBinding Light={StaticResource Slate700}, Dark={StaticResource Slate300}}" FontSize="14" FontAttributes="Bold" Margin="4,0,0,0" />
                        <Border Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate700}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate800}}" StrokeShape="RoundRectangle 12" HeightRequest="56">
                            <Grid ColumnDefinitions="48, *, 48">
                                <Label Text="lock" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Entry Grid.Column="1" IsPassword="True" Placeholder="Enter password" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" PlaceholderColor="{StaticResource Slate400}" BackgroundColor="Transparent" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="visibility_off" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="16" Margin="0, 24, 0, 0">
                    <Button Text="Sign In" BackgroundColor="{StaticResource Primary}" TextColor="White" FontAttributes="Bold" HeightRequest="56" CornerRadius="12" />

                    <Grid ColumnDefinitions="*, Auto, *" Margin="0, 8">
                        <BoxView Grid.Column="0" HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate700}}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="OR BIOMETRIC" TextColor="{StaticResource Slate500}" FontSize="12" Margin="16, 0" VerticalOptions="Center" />
                        <BoxView Grid.Column="2" HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate700}}" VerticalOptions="Center" />
                    </Grid>

                    <Button Text="Use Biometric ID" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate800}}" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Slate100}}" BorderColor="#33003366" BorderWidth="2" FontAttributes="Bold" HeightRequest="56" CornerRadius="12" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, Auto" Margin="0, 24, 0, 24">
                    <Label Text="Forgot Password?" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Slate400}}" FontSize="14" />
                    <Label Grid.Column="1" Text="Help Center" TextColor="{StaticResource Slate500}" FontSize="14" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Padding="24" Spacing="8">
            <Label Text="location_on" FontFamily="MaterialIcons" TextColor="LimeGreen" FontSize="16" VerticalOptions="Center" />
            <Label Text="GPS Location Services Active" TextColor="{StaticResource Slate400}" FontSize="12" VerticalOptions="Center" />
        </HorizontalStackLayout>

    </Grid>
</ContentPage>