<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceApp.Mobile.Views.SettingsPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate100}, Dark={StaticResource Slate800}}" VerticalOptions="End" Margin="-16,0" />

            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="Transparent" StrokeThickness="0">
                    <Label Text="arrow_back" FontFamily="MaterialIcons" FontSize="24" TextColor="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Settings" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="0">

                <VerticalStackLayout Padding="24" HorizontalOptions="Center" Spacing="16">
                    <Grid WidthRequest="128" HeightRequest="128" HorizontalOptions="Center">
                        <Border WidthRequest="128" HeightRequest="128" Stroke="{StaticResource Primary}" StrokeThickness="4" StrokeShape="RoundRectangle 64" Padding="4">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 60">
                                <Image Source="profile_placeholder.png" Aspect="AspectFill" />
                            </Border>
                        </Border>

                        <Border BackgroundColor="{StaticResource Primary}" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,4,4">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.3" />
                            </Border.Shadow>
                            <Label Text="edit" FontFamily="MaterialIcons" TextColor="White" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="Derrek Kimani" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" HorizontalOptions="Center" />
                        <Label Text="BSc Mathematics &amp; Computer Science" FontSize="14" TextColor="{StaticResource Slate500}" HorizontalOptions="Center" />
                        <Label Text="ID: 20240589 • Class of '26" FontSize="12" TextColor="{StaticResource Slate400}" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Button Text="Edit Profile Details" BackgroundColor="#1A003366" TextColor="{StaticResource Primary}" FontAttributes="Bold" HeightRequest="44" CornerRadius="8" Margin="0,8,0,0" WidthRequest="250" />
                </VerticalStackLayout>

                <ContentView BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark=#080F172A}" Padding="16,8">
                    <Label Text="NOTIFICATIONS" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Slate400}" CharacterSpacing="1" />
                </ContentView>

                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0" Margin="0,0,16,0">
                            <Label Text="schedule" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Class starting" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate800}, Dark={StaticResource Slate100}}" />
                            <Label Text="Alerts 15 mins before lecture" FontSize="12" TextColor="{StaticResource Slate500}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="True" OnColor="{StaticResource Primary}" VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}" />

                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0" Margin="0,0,16,0">
                            <Label Text="task_alt" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Attendance confirmed" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate800}, Dark={StaticResource Slate100}}" />
                            <Label Text="Confirmation of GPS check-in" FontSize="12" TextColor="{StaticResource Slate500}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="True" OnColor="{StaticResource Primary}" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <ContentView BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark=#080F172A}" Padding="16,8">
                    <Label Text="SECURITY &amp; PRIVACY" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Slate400}" CharacterSpacing="1" />
                </ContentView>

                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0" Margin="0,0,16,0">
                            <Label Text="lock_reset" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Reset Password" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate800}, Dark={StaticResource Slate100}}" />
                            <Label Text="Update your account password" FontSize="12" TextColor="{StaticResource Slate500}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="chevron_right" FontFamily="MaterialIcons" TextColor="{StaticResource Slate300}" FontSize="24" VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}" />

                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0" Margin="0,0,16,0">
                            <Label Text="fingerprint" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Update Biometrics" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate800}, Dark={StaticResource Slate100}}" />
                            <Label Text="Set up Face ID or Fingerprint" FontSize="12" TextColor="{StaticResource Slate500}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="chevron_right" FontFamily="MaterialIcons" TextColor="{StaticResource Slate300}" FontSize="24" VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}" />

                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#1AE53935" StrokeThickness="0" Margin="0,0,16,0">
                            <Label Text="logout" FontFamily="MaterialIcons" TextColor="Firebrick" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Sign Out" FontAttributes="Bold" TextColor="Firebrick" />
                            <Label Text="Log out of this device" FontSize="12" TextColor="{StaticResource Slate400}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Padding="32" Spacing="4" HorizontalOptions="Center" Margin="0,0,0,32">
                    <Label Text="App Version 2.4.0 (Build 502)" FontSize="12" TextColor="{StaticResource Slate400}" HorizontalOptions="Center" />
                    <Label Text="© 2026 JKUAT Attendance System" FontSize="12" TextColor="{StaticResource Slate400}" HorizontalOptions="Center" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Padding="16,8,16,24" ColumnDefinitions="*,*,*,*">
            <BoxView Grid.ColumnSpan="4" HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" VerticalOptions="Start" Margin="-16,-8,-16,0" />

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="home" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Home" TextColor="{StaticResource Slate400}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="calendar_today" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Schedule" TextColor="{StaticResource Slate400}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="location_on" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Attendance" TextColor="{StaticResource Slate400}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="settings" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Settings" TextColor="{StaticResource Primary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>