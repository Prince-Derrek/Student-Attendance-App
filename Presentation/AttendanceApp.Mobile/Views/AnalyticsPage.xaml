<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceApp.Mobile.Views.AnalyticsPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}">
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" VerticalOptions="End" Margin="-16,0" />

            <Grid ColumnDefinitions="40, *, 40">
                <Label Grid.Column="0" Text="arrow_back" FontFamily="MaterialIcons" FontSize="24" TextColor="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Attendance Analytics" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" HorizontalOptions="Center" VerticalOptions="Center" />
                <Border Grid.Column="2" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="Transparent" StrokeThickness="0">
                    <Label Text="calendar_month" FontFamily="MaterialIcons" FontSize="24" TextColor="{StaticResource Slate500}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16" Spacing="0">

                <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="24" Margin="0,0,0,24">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <Label Text="OVERALL ATTENDANCE" TextColor="{StaticResource Slate500}" FontSize="12" HorizontalOptions="Center" CharacterSpacing="1" Margin="0,0,0,16" />

                        <Grid WidthRequest="160" HeightRequest="160" HorizontalOptions="Center" Margin="0,0,0,24">
                            <Ellipse Stroke="{AppThemeBinding Light={StaticResource Slate100}, Dark={StaticResource Slate800}}" StrokeThickness="12" Fill="Transparent" />
                            <Ellipse Stroke="{StaticResource Primary}" StrokeThickness="12" Fill="Transparent" StrokeDashArray="42, 8" StrokeLineCap="Round" Rotation="-90" />

                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="85%" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                                <Label Text="Present" FontSize="12" TextColor="{StaticResource Slate500}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate100}, Dark={StaticResource Slate800}}" Margin="-24,0,-24,24" />

                        <Grid ColumnDefinitions="*, *, *">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                <Label Text="42" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" HorizontalOptions="Center" />
                                <Label Text="Present" FontSize="12" TextColor="{StaticResource Slate500}" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <BoxView Grid.Column="1" WidthRequest="1" Color="{AppThemeBinding Light={StaticResource Slate100}, Dark={StaticResource Slate800}}" HorizontalOptions="Start" Margin="0,-8" />
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="05" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" HorizontalOptions="Center" />
                                <Label Text="Absent" FontSize="12" TextColor="{StaticResource Slate500}" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <BoxView Grid.Column="2" WidthRequest="1" Color="{AppThemeBinding Light={StaticResource Slate100}, Dark={StaticResource Slate800}}" HorizontalOptions="Start" Margin="0,-8" />
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label Text="02" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" HorizontalOptions="Center" />
                                <Label Text="Excused" FontSize="12" TextColor="{StaticResource Slate500}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Download Monthly Report" BackgroundColor="{StaticResource Primary}" TextColor="White" FontAttributes="Bold" FontSize="16" HeightRequest="48" CornerRadius="12" Margin="0,0,0,24">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="MaterialIcons" Glyph="download" Color="White" Size="20" />
                    </Button.ImageSource>
                </Button>

                <Grid ColumnDefinitions="*, Auto" Margin="4,0,4,16">
                    <Label Grid.Column="0" Text="Recent History" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="View All" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                </Grid>

                <VerticalStackLayout Spacing="12">
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                            <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0">
                                <Label Text="functions" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Advanced Calculus" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" />
                                <Label Text="Mar 12, 2026 • 09:00 AM" FontSize="12" TextColor="{StaticResource Slate500}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="#E6F4EA" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,4" VerticalOptions="Center">
                                <Label Text="Present" TextColor="ForestGreen" FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                            <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0">
                                <Label Text="biotech" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Quantum Physics" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" />
                                <Label Text="Mar 11, 2026 • 11:30 AM" FontSize="12" TextColor="{StaticResource Slate500}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="#FCE8E8" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,4" VerticalOptions="Center">
                                <Label Text="Absent" TextColor="Firebrick" FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                            <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0">
                                <Label Text="history_edu" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="World Literature" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" />
                                <Label Text="Mar 09, 2026 • 02:00 PM" FontSize="12" TextColor="{StaticResource Slate500}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="#E8F0FE" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,4" VerticalOptions="Center">
                                <Label Text="Excused" TextColor="RoyalBlue" FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                            <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 8" BackgroundColor="#1A003366" StrokeThickness="0">
                                <Label Text="computer" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Data Structures" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate100}}" />
                                <Label Text="Mar 06, 2026 • 10:00 AM" FontSize="12" TextColor="{StaticResource Slate500}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="#E6F4EA" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,4" VerticalOptions="Center">
                                <Label Text="Present" TextColor="ForestGreen" FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Slate900}}" Padding="16,8,16,24" ColumnDefinitions="*,*,*,*">
            <BoxView Grid.ColumnSpan="4" HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource Slate800}}" VerticalOptions="Start" Margin="-16,-8,-16,0" />

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="home" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Home" TextColor="{StaticResource Slate400}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="school" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Classes" TextColor="{StaticResource Slate400}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Grid HorizontalOptions="Center">
                    <Label Text="pie_chart" FontFamily="MaterialIcons" TextColor="{StaticResource Primary}" FontSize="24" />
                    <BoxView Color="{StaticResource Primary}" WidthRequest="4" HeightRequest="4" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,-6,0,0" />
                </Grid>
                <Label Text="Analytics" TextColor="{StaticResource Primary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                <Label Text="person" FontFamily="MaterialIcons" TextColor="{StaticResource Slate400}" FontSize="24" HorizontalOptions="Center" />
                <Label Text="Profile" TextColor="{StaticResource Slate400}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>